MODEL_NAME="gemini-2.5-pro"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_GENAI_USE_VERTEXAI="True"

# Full resource path of the Vertex AI Search serving config.
# Format: projects/{project}/locations/{location}/collections/default_collection/dataStores/{datastore_id}/servingConfigs/default_search
DATASTORE_PATH=""

# GCS bucket connected to the Vertex AI Search Data Connector (used by make sync-data)
GCS_BUCKET_NAME=""

# Optional: object prefix inside the bucket (default: knowledge_base)
# GCS_PREFIX="knowledge_base"

# Set to TRUE to skip real API calls and return mock results (useful for unit tests)
# INTEGRATION_TEST="TRUE"
