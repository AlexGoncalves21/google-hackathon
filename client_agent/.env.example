MODEL_NAME="gemini-2.5-pro"
MAIN_AGENT_BASE_URL="http://localhost:8001"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_GENAI_USE_VERTEXAI="True"

# Optional: full Vertex AI Search serving config path used for documentation grounding.
# DATASTORE_PATH="projects/your-project/locations/global/collections/default_collection/dataStores/your-datastore/servingConfigs/default_search"

# Optional: set to True when MAIN_AGENT_BASE_URL points at a private Cloud Run service.
# If omitted, the client defaults to auth for non-local URLs and no auth for localhost.
# MAIN_AGENT_REQUIRE_AUTH="True"

# Optional: Cloud Run IAM audience override. Defaults to MAIN_AGENT_BASE_URL.
# MAIN_AGENT_AUDIENCE="https://your-service-xxxxx-uc.a.run.app"

# Optional: short-lived bearer token for local testing against a private deployed service.
# MAIN_AGENT_AUTH_TOKEN=""
